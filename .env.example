# OpenRouter API Configuration
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model to use (default: free open-source model)
OPENROUTER_MODEL=moonshotai/kimi-k2:free

# Enable live LLM generation (set to "true" to use real API calls)
OPENROUTER_ENABLE_LIVE_GENERATION=true

# Server configuration
PORT=8000
HOSTNAME=0.0.0.0

# Storage and cache (optional for MVP)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_os
REDIS_URL=redis://localhost:6379
